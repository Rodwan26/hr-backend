# ===========================================
# Application Environment
# ===========================================

# Set to 'production' for production deployment
APP_ENV=production

# ===========================================
# Database
# ===========================================

# PostgreSQL connection string (Render PostgreSQL)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=your-postgresql-connection-string

# ===========================================
# Security
# ===========================================

# JWT Secret Key - Generate a secure random string (64+ characters)
# Example: openssl rand -hex 64
SECRET_KEY=generate-a-secure-random-key-here

# ===========================================
# AI Service (OpenRouter)
# ===========================================

# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# AI Model (optional - defaults to google/gemini-2.0-flash-001)
AI_MODEL_NAME=google/gemini-2.0-flash-001

# AI Kill Switch - Set to 'true' to disable AI features
AI_KILL_SWITCH=false

# ===========================================
# CORS Configuration
# ===========================================

# Comma-separated list of allowed origins
# Include your Vercel frontend URL(s)
# Example: https://hr-frontend.vercel.app,https://hr-frontend-git-main.vercel.app
CORS_ORIGINS=https://hr-frontend.vercel.app

# ===========================================
# Default Admin User (optional)
# ===========================================

# These are only used when the database is empty
# Remove in production and create admin through the setup page
DEFAULT_ADMIN_EMAIL=admin@company.com
DEFAULT_ADMIN_PASSWORD=change-this-password-in-production

# ===========================================
# SMTP Configuration (optional)
# ===========================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=noreply@hr-platform.com

# ===========================================
# Feature Flags
# ===========================================

ENABLE_BURNOUT_AI=true
ENABLE_ONBOARDING_AI=true
ENABLE_CACHING=true

# ===========================================
# Build Information (auto-generated)
# ===========================================

BUILD_ID=local
COMMIT_HASH=HEAD
